<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>مدير المبيعات | الروائع ERP</title>
    <link rel="manifest" href="../manifest.json">
    <meta name="theme-color" content="#1e3a8a">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dexie@3/dist/dexie.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:Tahoma,sans-serif;background:#f1f5f9;-webkit-tap-highlight-color:transparent}
        .auth-container{background:linear-gradient(135deg,#0f172a 0%,#1e3a8a 40%,#1e40af 100%)}
        .input-field:focus{border-color:#1e3a8a;box-shadow:0 0 0 3px rgba(30,58,138,0.1)}
        @keyframes fadeIn{from{opacity:0}to{opacity:1}}
        .animate-fadeIn{animation:fadeIn .3s}
        .card{background:#fff;border-radius:20px;padding:1.25rem;box-shadow:0 4px 15px rgba(0,0,0,0.05)}
        .stat-card{background:#fff;border-radius:16px;padding:1rem;box-shadow:0 4px 6px rgba(0,0,0,0.02)}
        .kpi-up{color:#10b981}.kpi-down{color:#ef4444}
        .heat-bar{height:8px;border-radius:4px;background:#e5e7eb;overflow:hidden}
        .heat-fill{height:100%;border-radius:4px;transition:width 0.5s}
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

<div id="loginScreen" class="fixed inset-0 z-[100] flex items-center justify-center auth-container p-4">
    <div class="bg-white rounded-[32px] shadow-2xl p-6 w-[92%] max-w-md">
        <div class="text-center mb-6">
            <div class="w-20 h-20 bg-gradient-to-br from-blue-800 to-blue-950 rounded-2xl mx-auto flex items-center justify-center shadow-lg mb-4"><i class="fa-solid fa-crown text-white text-3xl"></i></div>
            <h1 class="font-black text-2xl text-gray-800">الروائع</h1><p class="text-xs text-gray-400 font-bold mt-1">مدير المبيعات</p>
        </div>
        <h2 class="text-lg font-bold text-gray-700 text-center mb-4">تسجيل الدخول إلى حسابك</h2>
        <div class="space-y-3">
            <div><label class="block text-xs font-bold text-gray-600 mb-1">البريد الإلكتروني <span class="text-red-500">*</span></label><input id="loginEmail" type="email" placeholder="example@domain.com" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-blue-800 focus:bg-white outline-none font-bold text-sm transition-all"></div>
            <div><label class="block text-xs font-bold text-gray-600 mb-1">كلمة السر <span class="text-red-500">*</span></label><div class="relative"><input id="loginPass" type="password" placeholder="••••••••" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-blue-800 focus:bg-white outline-none font-bold text-sm transition-all pr-12"><button type="button" onclick="App.togglePass()" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-gray-600"><i id="passIcon" class="fa-solid fa-eye"></i></button></div></div>
        </div>
        <button onclick="App.doLogin()" class="w-full bg-gradient-to-r from-blue-800 to-blue-900 text-white py-3.5 rounded-xl font-black text-sm shadow-lg shadow-blue-200 hover:shadow-xl transition-all mt-4">تسجيل الدخول</button>
        <p id="loginMsg" class="text-center text-xs text-red-500 font-bold mt-3 hidden"></p>
    </div>
</div>

<div id="mainApp" class="hidden flex flex-col h-full">
    <header class="bg-blue-900 text-white p-4 flex items-center justify-between sticky top-0 z-30 shadow-md flex-shrink-0">
        <span class="font-black text-sm">مدير المبيعات</span>
        <div class="flex items-center gap-2"><span class="text-xs font-bold" id="headerUserName"></span><button onclick="App.doLogout()" class="bg-white/10 w-8 h-8 rounded-full"><i class="fa-solid fa-arrow-right-from-bracket text-xs"></i></button></div>
    </header>
    <div class="flex gap-1 p-2 bg-white border-b overflow-x-auto flex-shrink-0">
        <button onclick="App.switchTab('performance')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm bg-blue-900 text-white" id="tab-performance">📊 KPI</button>
        <button onclick="App.switchTab('targets')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm text-gray-500" id="tab-targets">🎯 الأهداف</button>
        <button onclick="App.switchTab('reports')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm text-gray-500" id="tab-reports">📋 التقارير</button>
    </div>
    <main id="mainContent" class="flex-1 overflow-y-auto p-4"></main>
</div>

<script>
var SUPABASE_URL = 'https://fiilmooggumokxanwiyx.supabase.co';
var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZpaWxtb29nZ3Vtb2t4YW53aXl4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg3MDkwOTIsImV4cCI6MjA5NDI4NTA5Mn0.LZScCxnCiRrTSCCBmTryszQpY1AwBgR2dkTBbC5kOc4';
var supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
var db = new Dexie('RW_SalesManager'); db.version(1).stores({ meta: 'key', cache: 'key' });
function byId(id) { return document.getElementById(id); }
function safeText(el, text) { if (el) el.textContent = text; }
function safeHTML(el, html) { if (el) el.innerHTML = html; }
function fmtNum(n) { return Number(n || 0).toLocaleString('ar-EG', {minimumFractionDigits: 2}); }
function toast(m, t) { Swal.fire({ toast: true, position: 'top', icon: t || 'info', title: m, showConfirmButton: false, timer: 2000 }); }

var App = {
    currentUser: null, currentTab: 'performance', charts: {},

    togglePass: function(){var p=byId('loginPass'),i=byId('passIcon');if(p.type==='password'){p.type='text';i.className='fa-solid fa-eye-slash';}else{p.type='password';i.className='fa-solid fa-eye';}},
    doLogin: function(){var e=byId('loginEmail').value.trim(),p=byId('loginPass').value.trim();if(!e||!p){byId('loginMsg').innerText='أدخل البريد الإلكتروني وكلمة المرور';byId('loginMsg').classList.remove('hidden');return;}byId('loginMsg').classList.add('hidden');var s=this;Swal.showLoading();supabase.auth.signInWithPassword({email:e,password:p}).then(function(r){Swal.close();if(r.error){byId('loginMsg').innerText=r.error.message;byId('loginMsg').classList.remove('hidden');}else{s.init();}}).catch(function(){Swal.close();byId('loginMsg').innerText='فشل الاتصال';byId('loginMsg').classList.remove('hidden');});},
    init: function(){var s=this;supabase.auth.getSession().then(function(r){if(r.data&&r.data.session){s.currentUser=r.data.session.user;var m=s.currentUser.user_metadata||{},isO=(m.isOwner===true||m.isOwner==='true'||m.role==='owner'||m.role==='مالك'),perms=m.permissions||[],has=isO||(Array.isArray(perms)&&perms.indexOf('reports')!==-1);if(!has){Swal.fire({title:'غير مصرح',text:'ليس لديك صلاحية التقارير',icon:'error'});supabase.auth.signOut();return;}safeText(byId('headerUserName'),m.name||s.currentUser.email);s.enterApp();}});},
    enterApp: function(){byId('loginScreen').classList.add('hidden');byId('mainApp').classList.remove('hidden');this.switchTab('performance');},
    doLogout: function(){var s=this;supabase.auth.signOut().then(function(){s.currentUser=null;byId('mainApp').classList.add('hidden');byId('loginScreen').classList.remove('hidden');byId('loginEmail').value='';byId('loginPass').value='';byId('loginMsg').classList.add('hidden');});},
    switchTab: function(t){this.currentTab=t;['performance','targets','reports'].forEach(function(x){var b=byId('tab-'+x);if(b){b.classList.remove('bg-blue-900','text-white');b.classList.add('text-gray-500');}});var a=byId('tab-'+t);if(a){a.classList.add('bg-blue-900','text-white');a.classList.remove('text-gray-500');}if(t==='performance')this.renderPerformance();else if(t==='targets')this.renderTargets();else if(t==='reports')this.renderReports();},
    destroyCharts: function(){for(var k in this.charts){if(this.charts.hasOwnProperty(k)&&this.charts[k]){this.charts[k].destroy();this.charts[k]=null;}}},

    // 🆕 KPI - أداء متقدم
    renderPerformance: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10 text-gray-400"><i class="fa-solid fa-spinner fa-spin text-2xl"></i></div>');
        var today=new Date().toISOString().split('T')[0];
        var firstDay=new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().split('T')[0];
        var prevFirst=new Date(new Date().getFullYear(),new Date().getMonth()-1,1).toISOString().split('T')[0];
        var prevLast=new Date(new Date().getFullYear(),new Date().getMonth(),0).toISOString().split('T')[0];
        var daysInMonth=new Date(new Date().getFullYear(),new Date().getMonth()+1,0).getDate();
        var todayDay=new Date().getDate();

        Promise.all([
            supabase.from('orders').select('total_amount,payment_type,order_date,area').gte('order_date',firstDay).lte('order_date',today),
            supabase.from('orders').select('total_amount').gte('order_date',prevFirst).lte('order_date',prevLast),
            supabase.from('users').select('email').in('role',['مندوب مبيعات','مندوب بيع مباشر','كاشير','تلي سيلز'])
        ]).then(function(r){
            var orders=r[0].data||[],prevOrders=r[1].data||[],users=r[2].data||[];
            var total=0,cash=0,credit=0,areaMap={};
            for(var i=0;i<orders.length;i++){total+=Number(orders[i].total_amount)||0;if(orders[i].payment_type==='نقدي')cash++;else credit++;var ar=orders[i].area||'غير محدد';areaMap[ar]=(areaMap[ar]||0)+(Number(orders[i].total_amount)||0);}
            var prevTotal=0;for(var j=0;j<prevOrders.length;j++)prevTotal+=Number(prevOrders[j].total_amount)||0;
            var growth=prevTotal>0?Math.round(((total-prevTotal)/prevTotal)*100):0;
            var avgOrder=orders.length>0?Math.round(total/orders.length):0;
            var projected=Math.round((total/todayDay)*daysInMonth);
            var dailyAvg=Math.round(total/todayDay);

            // أفضل منطقة
            var topArea='',topAreaVal=0;
            for(var k in areaMap){if(areaMap.hasOwnProperty(k)&&areaMap[k]>topAreaVal){topAreaVal=areaMap[k];topArea=k;}}

            s.destroyCharts();

            var html='<h2 class="text-lg font-black mb-2">📊 مؤشرات الأداء – الشهر الحالي</h2>';
            html+='<p class="text-xs text-gray-400 mb-4">مقارنة بالشهر السابق</p>';

            html+='<div class="grid grid-cols-2 gap-3 mb-4">';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">إجمالي المبيعات</p><p class="text-2xl font-black text-blue-900">'+fmtNum(total)+' ج.م</p><p class="text-xs mt-1 '+(growth>=0?'kpi-up':'kpi-down')+'"><i class="fa-solid fa-'+(growth>=0?'arrow-up':'arrow-down')+' ml-1"></i> '+(growth>=0?'+':'')+growth+'%</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">عدد الأوردرات</p><p class="text-2xl font-black text-emerald-600">'+orders.length+'</p><p class="text-xs text-gray-400 mt-1">'+fmtNum(avgOrder)+' ج.م متوسط</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">توقعات الشهر</p><p class="text-2xl font-black text-purple-600">'+fmtNum(projected)+' ج.م</p><p class="text-xs text-gray-400 mt-1">'+fmtNum(dailyAvg)+' ج.م/يومياً</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">أفضل منطقة</p><p class="text-xl font-black text-amber-600">'+(topArea||'---')+'</p><p class="text-xs text-gray-400 mt-1">'+fmtNum(topAreaVal)+' ج.م</p></div>';
            html+='</div>';

            html+='<div class="grid grid-cols-2 gap-3 mb-4">';
            html+='<div class="stat-card text-center"><p class="text-xs text-gray-400">💵 نقدي</p><p class="text-xl font-black text-green-600">'+cash+'</p><p class="text-xs text-gray-400">'+fmtNum(cash>0?Math.round((cash/orders.length)*100):0)+'%</p></div>';
            html+='<div class="stat-card text-center"><p class="text-xs text-gray-400">📋 آجل</p><p class="text-xl font-black text-orange-600">'+credit+'</p><p class="text-xs text-gray-400">'+fmtNum(credit>0?Math.round((credit/orders.length)*100):0)+'%</p></div>';
            html+='<div class="stat-card text-center"><p class="text-xs text-gray-400">👥 المندوبين</p><p class="text-xl font-black text-indigo-600">'+users.length+'</p></div>';
            html+='<div class="stat-card text-center"><p class="text-xs text-gray-400">📈 نمو</p><p class="text-xl font-black '+(growth>=0?'kpi-up':'kpi-down')+'">'+(growth>=0?'+':'')+growth+'%</p></div>';
            html+='</div>';

            // تريند + مبيعات المناطق
            html+='<div class="card mb-4"><h3 class="font-bold mb-3">📈 تريند المبيعات اليومية</h3><div style="height:250px"><canvas id="chart-trend"></canvas></div></div>';
            html+='<div class="card mb-4"><h3 class="font-bold mb-3">🗺️ المبيعات حسب المنطقة</h3><div style="height:250px"><canvas id="chart-area"></canvas></div></div>';

            safeHTML(byId('mainContent'),html);

            setTimeout(function(){
                var days={},labels=[],data=[];
                for(var i=0;i<orders.length;i++){var d=orders[i].order_date||'';days[d]=(days[d]||0)+(Number(orders[i].total_amount)||0);}
                var st=new Date(firstDay),en=new Date(today);
                for(var dt=new Date(st);dt<=en;dt.setDate(dt.getDate()+1)){labels.push(dt.toISOString().split('T')[0]);data.push(days[labels[labels.length-1]]||0);}
                var ctx=byId('chart-trend');if(ctx&&typeof Chart!=='undefined'){s.charts['trend']=new Chart(ctx.getContext('2d'),{type:'line',data:{labels:labels,datasets:[{label:'المبيعات (ج.م)',data:data,borderColor:'#1e3a8a',backgroundColor:'rgba(30,58,138,0.1)',fill:true,tension:0.4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,position:'top'}}}});}

                var aLabels=[],aData=[];
                for(var k in areaMap){if(areaMap.hasOwnProperty(k)){aLabels.push(k);aData.push(areaMap[k]);}}
                var ctx2=byId('chart-area');if(ctx2&&typeof Chart!=='undefined'){s.charts['area']=new Chart(ctx2.getContext('2d'),{type:'doughnut',data:{labels:aLabels,datasets:[{data:aData,backgroundColor:['#1e3a8a','#10b981','#f59e0b','#ef4444','#8b5cf6','#ec4899','#06b6d4']}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:true,position:'right'}}}});}
            },300);
        }).catch(function(){safeHTML(byId('mainContent'),'<div class="text-center py-10 text-red-500">فشل تحميل البيانات</div>');});
    },

    // 🆕 الأهداف مع KPIs
    renderTargets: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10 text-gray-400"><i class="fa-solid fa-spinner fa-spin text-2xl"></i></div>');
        var today=new Date().toISOString().split('T')[0];
        var firstDay=new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().split('T')[0];
        supabase.from('users').select('email,name,role').in('role',['مندوب مبيعات','مندوب بيع مباشر','كاشير','تلي سيلز']).then(function(uR){
            var users=uR.data||[];
            supabase.from('orders').select('created_by,total_amount').gte('order_date',firstDay).lte('order_date',today).then(function(oR){
                var orders=oR.data||[],stats={},grandTotal=0;
                for(var i=0;i<orders.length;i++){var by=orders[i].created_by||'';stats[by]=(stats[by]||0)+(Number(orders[i].total_amount)||0);grandTotal+=Number(orders[i].total_amount)||0;}
                users.sort(function(a,b){return(stats[b.email]||0)-(stats[a.email]||0);});
                var html='<h2 class="text-lg font-black mb-2">🎯 الأهداف – الشهر الحالي</h2>';
                html+='<p class="text-xs text-gray-400 mb-4">إجمالي المبيعات: '+fmtNum(grandTotal)+' ج.م</p>';
                if(!users.length){html+='<div class="card text-center text-gray-500">لا يوجد مندوبون</div>';}
                else{for(var j=0;j<users.length;j++){var u=users[j],sold=stats[u.email]||0,target=50000,pct=Math.min(100,Math.round((sold/target)*100)),barC=pct>=100?'bg-emerald-500':pct>=50?'bg-blue-500':'bg-red-400',share=grandTotal>0?Math.round((sold/grandTotal)*100):0;
                html+='<div class="card mb-3"><div class="flex justify-between items-center mb-2"><span class="font-bold">'+(u.name||u.email)+'</span><span class="text-xs text-gray-400">'+(u.role||'')+' | حصة: '+share+'%</span></div>';
                html+='<div class="flex justify-between text-xs font-bold mb-1"><span>'+fmtNum(sold)+' ج.م</span><span>الهدف: '+fmtNum(target)+' ج.م</span></div>';
                html+='<div class="heat-bar"><div class="heat-fill '+barC+'" style="width:'+pct+'%"></div></div><p class="text-xs text-gray-400 mt-1">'+pct+'% من الهدف</p></div>';}}
                safeHTML(byId('mainContent'),html);
            });
        }).catch(function(){safeHTML(byId('mainContent'),'<div class="text-center py-10 text-red-500">فشل تحميل البيانات</div>');});
    },

    renderReports: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10 text-gray-400"><i class="fa-solid fa-spinner fa-spin text-2xl"></i></div>');
        var today=new Date().toISOString().split('T')[0];
        var td=new Date();td.setDate(td.getDate()-30);var fromDef=td.toISOString().split('T')[0];
        Promise.all([
            supabase.from('orders').select('customer_name,total_amount').gte('order_date',fromDef).lte('order_date',today),
            supabase.from('order_details').select('item_name,qty').gte('created_at',fromDef).lte('created_at',today)
        ]).then(function(r){
            var orders=r[0].data||[],details=r[1].data||[];
            var cMap={};for(var i=0;i<orders.length;i++){var cn=orders[i].customer_name||'غير محدد';cMap[cn]=(cMap[cn]||0)+(Number(orders[i].total_amount)||0);}
            var topC=[];for(var k in cMap){if(cMap.hasOwnProperty(k))topC.push({name:k,total:cMap[k]});}topC.sort(function(a,b){return b.total-a.total;});topC=topC.slice(0,10);
            var iMap={};for(var j=0;j<details.length;j++){var inm=details[j].item_name||'غير محدد';iMap[inm]=(iMap[inm]||0)+(Number(details[j].qty)||0);}
            var topI=[];for(var k2 in iMap){if(iMap.hasOwnProperty(k2))topI.push({name:k2,qty:iMap[k2]});}topI.sort(function(a,b){return b.qty-a.qty;});topI=topI.slice(0,10);
            var html='<h2 class="text-lg font-black mb-4">📋 تقارير – آخر ٣٠ يوماً</h2>';
            html+='<div class="card mb-4"><h3 class="font-bold mb-2"><i class="fa-solid fa-users ml-2 text-blue-600"></i> أفضل ١٠ عملاء</h3>';
            if(!topC.length){html+='<p class="text-gray-400 text-center">لا توجد بيانات</p>';}else{html+='<table class="w-full text-sm"><thead><tr class="bg-gray-50"><th class="p-2">العميل</th><th class="p-2 text-center">الإجمالي</th></tr></thead><tbody>';for(var c=0;c<topC.length;c++){html+='<tr class="border-t"><td class="p-2 font-semibold">'+topC[c].name+'</td><td class="p-2 text-center font-bold">'+fmtNum(topC[c].total)+' ج.م</td></tr>';}html+='</tbody></table>';}
            html+='</div><div class="card"><h3 class="font-bold mb-2"><i class="fa-solid fa-boxes-stacked ml-2 text-purple-600"></i> أفضل ١٠ أصناف</h3>';
            if(!topI.length){html+='<p class="text-gray-400 text-center">لا توجد بيانات</p>';}else{html+='<table class="w-full text-sm"><thead><tr class="bg-gray-50"><th class="p-2">الصنف</th><th class="p-2 text-center">الكمية</th></tr></thead><tbody>';for(var it=0;it<topI.length;it++){html+='<tr class="border-t"><td class="p-2 font-semibold">'+topI[it].name+'</td><td class="p-2 text-center font-bold">'+topI[it].qty+'</td></tr>';}html+='</tbody></table>';}
            html+='</div>';safeHTML(byId('mainContent'),html);
        }).catch(function(){safeHTML(byId('mainContent'),'<div class="text-center py-10 text-red-500">فشل تحميل التقارير</div>');});
    }
};
if('serviceWorker' in navigator){navigator.serviceWorker.register('../sw.js').catch(function(){});}
document.addEventListener('DOMContentLoaded',function(){App.init();});
</script>
</body>
</html>
