<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>مشرف المشتريات | الروائع ERP</title>
    <link rel="manifest" href="../manifest.json">
    <meta name="theme-color" content="#a855f7">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/dexie@3/dist/dexie.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:Tahoma,sans-serif;background:#f1f5f9}
        .auth-container{background:linear-gradient(135deg,#581c87 0%,#7e22ce 40%,#a855f7 100%)}
        .input-field:focus{border-color:#a855f7;box-shadow:0 0 0 3px rgba(168,85,247,0.1)}
        .card{background:#fff;border-radius:20px;padding:1.25rem;box-shadow:0 4px 15px rgba(0,0,0,0.05)}
        .stat-card{background:#fff;border-radius:16px;padding:1rem;box-shadow:0 4px 6px rgba(0,0,0,0.02)}
        .kpi-up{color:#10b981}.kpi-down{color:#ef4444}
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

<div id="loginScreen" class="fixed inset-0 z-[100] flex items-center justify-center auth-container p-4">
    <div class="bg-white rounded-[32px] shadow-2xl p-6 w-[92%] max-w-md">
        <div class="text-center mb-6"><div class="w-20 h-20 bg-gradient-to-br from-fuchsia-600 to-fuchsia-800 rounded-2xl mx-auto flex items-center justify-center shadow-lg mb-4"><i class="fa-solid fa-clipboard-check text-white text-3xl"></i></div><h1 class="font-black text-2xl text-gray-800">الروائع</h1><p class="text-xs text-gray-400">مشرف المشتريات</p></div>
        <h2 class="text-lg font-bold text-gray-700 text-center mb-4">تسجيل الدخول</h2>
        <div class="space-y-3"><div><input id="loginEmail" type="email" placeholder="البريد الإلكتروني" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-fuchsia-600 outline-none font-bold text-sm"></div><div class="relative"><input id="loginPass" type="password" placeholder="كلمة السر" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-fuchsia-600 outline-none font-bold text-sm pr-12"><button type="button" onclick="App.togglePass()" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 text-gray-400"><i id="passIcon" class="fa-solid fa-eye"></i></button></div></div>
        <button onclick="App.doLogin()" class="w-full bg-gradient-to-r from-fuchsia-600 to-fuchsia-700 text-white py-3.5 rounded-xl font-black text-sm shadow-lg mt-4">تسجيل الدخول</button>
        <p id="loginMsg" class="text-center text-xs text-red-500 font-bold mt-3 hidden"></p>
    </div>
</div>

<div id="mainApp" class="hidden flex flex-col h-full">
    <header class="bg-fuchsia-700 text-white p-4 flex items-center justify-between sticky top-0 z-30 shadow-md flex-shrink-0">
        <span class="font-black text-sm">مشرف المشتريات</span>
        <div class="flex items-center gap-2"><span class="text-xs font-bold" id="headerUserName"></span><button onclick="App.doLogout()" class="bg-white/10 w-8 h-8 rounded-full"><i class="fa-solid fa-arrow-right-from-bracket text-xs"></i></button></div>
    </header>
    <div class="flex gap-1 p-2 bg-white border-b overflow-x-auto flex-shrink-0">
        <button onclick="App.switchTab('dashboard')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm bg-fuchsia-600 text-white" id="tab-dashboard">📊 KPI</button>
        <button onclick="App.switchTab('orders')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm text-gray-500" id="tab-orders">📋 الأوامر</button>
        <button onclick="App.switchTab('suppliers')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm text-gray-500" id="tab-suppliers">🏭 الموردين</button>
    </div>
    <main id="mainContent" class="flex-1 overflow-y-auto p-4"></main>
</div>

<script>
var SUPABASE_URL = 'https://fiilmooggumokxanwiyx.supabase.co';
var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZpaWxtb29nZ3Vtb2t4YW53aXl4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg3MDkwOTIsImV4cCI6MjA5NDI4NTA5Mn0.LZScCxnCiRrTSCCBmTryszQpY1AwBgR2dkTBbC5kOc4';
var supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
var db = new Dexie('RW_PurchSupervisor'); db.version(1).stores({ meta: 'key' });
function byId(id) { return document.getElementById(id); }
function safeText(el, text) { if (el) el.textContent = text; }
function safeHTML(el, html) { if (el) el.innerHTML = html; }
function fmtNum(n) { return Number(n || 0).toLocaleString('ar-EG', {minimumFractionDigits: 2}); }
function toast(m, t) { Swal.fire({ toast: true, position: 'top', icon: t || 'info', title: m, showConfirmButton: false, timer: 2000 }); }

var App = {
    currentUser: null,
    togglePass: function(){var p=byId('loginPass'),i=byId('passIcon');if(p.type==='password'){p.type='text';i.className='fa-solid fa-eye-slash';}else{p.type='password';i.className='fa-solid fa-eye';}},
    doLogin: function(){var e=byId('loginEmail').value.trim(),p=byId('loginPass').value.trim();if(!e||!p){byId('loginMsg').innerText='أدخل البيانات';byId('loginMsg').classList.remove('hidden');return;}byId('loginMsg').classList.add('hidden');var s=this;Swal.showLoading();supabase.auth.signInWithPassword({email:e,password:p}).then(function(r){Swal.close();if(r.error){byId('loginMsg').innerText=r.error.message;byId('loginMsg').classList.remove('hidden');}else{s.init();}}).catch(function(){Swal.close();});},
    init: function(){var s=this;supabase.auth.getSession().then(function(r){if(r.data&&r.data.session){s.currentUser=r.data.session.user;var m=s.currentUser.user_metadata||{},isO=(m.isOwner===true||m.isOwner==='true'),perms=m.permissions||[],has=isO||(Array.isArray(perms)&&perms.indexOf('purchases')!==-1);if(!has){Swal.fire({title:'غير مصرح',icon:'error'});supabase.auth.signOut();return;}safeText(byId('headerUserName'),m.name||s.currentUser.email);s.enterApp();}});},
    enterApp: function(){byId('loginScreen').classList.add('hidden');byId('mainApp').classList.remove('hidden');this.switchTab('dashboard');},
    doLogout: function(){supabase.auth.signOut().then(function(){byId('mainApp').classList.add('hidden');byId('loginScreen').classList.remove('hidden');});},
    switchTab: function(t){['dashboard','orders','suppliers'].forEach(function(x){var b=byId('tab-'+x);if(b){b.classList.remove('bg-fuchsia-600','text-white');b.classList.add('text-gray-500');}});var a=byId('tab-'+t);if(a){a.classList.add('bg-fuchsia-600','text-white');a.classList.remove('text-gray-500');}if(t==='dashboard')this.renderDashboard();else if(t==='orders')this.renderOrders();else if(t==='suppliers')this.renderSuppliers();},

    renderDashboard: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10"><i class="fa-solid fa-spinner fa-spin"></i></div>');
        var today=new Date().toISOString().split('T')[0],firstDay=new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().split('T')[0];
        Promise.all([supabase.from('purchase_orders').select('status,total_amount').gte('po_date',firstDay).lte('po_date',today),supabase.from('suppliers').select('supplier_code')]).then(function(r){
            var orders=r[0].data||[],supp=r[1].data||[];var total=0,draft=0,sent=0,received=0;
            for(var i=0;i<orders.length;i++){total+=Number(orders[i].total_amount)||0;if(orders[i].status==='Draft')draft++;else if(orders[i].status==='Sent')sent++;else if(orders[i].status==='Received')received++;}
            var html='<h2 class="text-lg font-black mb-4">📊 مؤشرات المشتريات – الشهر</h2>';
            html+='<div class="grid grid-cols-2 gap-3 mb-4">';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">إجمالي المشتريات</p><p class="text-2xl font-black text-fuchsia-600">'+fmtNum(total)+' ج.م</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">عدد الأوامر</p><p class="text-2xl font-black text-fuchsia-600">'+orders.length+'</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">📋 مسودة</p><p class="text-xl font-black text-amber-600">'+draft+'</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">📤 مُرسلة</p><p class="text-xl font-black text-blue-600">'+sent+'</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">✅ مستلمة</p><p class="text-xl font-black text-green-600">'+received+'</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">🏭 الموردين</p><p class="text-xl font-black text-purple-600">'+supp.length+'</p></div>';
            html+='</div>';safeHTML(byId('mainContent'),html);
        });
    },

    renderOrders: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10"><i class="fa-solid fa-spinner fa-spin"></i></div>');
        supabase.from('purchase_orders').select('po_code,po_date,supplier_name,status,total_amount').order('po_date',{ascending:false}).limit(50).then(function(r){var orders=r.data||[],html='<h2 class="text-lg font-black mb-4">📋 جميع أوامر الشراء</h2>';
        if(!orders.length){html+='<div class="text-center text-gray-400 py-10">لا توجد أوامر</div>';}else{for(var i=0;i<orders.length;i++){var o=orders[i],sc=o.status==='Received'?'bg-green-100 text-green-700':o.status==='Partially Received'?'bg-orange-100 text-orange-700':o.status==='Sent'?'bg-blue-100 text-blue-700':'bg-amber-100 text-amber-700';
        html+='<div class="card mb-2"><div class="flex justify-between"><div><span class="font-bold">'+o.po_code+'</span><p class="text-xs text-gray-400">'+o.po_date+' | '+o.supplier_name+'</p></div><div><span class="px-2 py-1 rounded-full text-xs font-bold '+sc+'">'+o.status+'</span><p class="font-black text-fuchsia-600 mt-1">'+fmtNum(o.total_amount)+' ج.م</p></div></div></div>';}}
        safeHTML(byId('mainContent'),html);});
    },

    renderSuppliers: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10"><i class="fa-solid fa-spinner fa-spin"></i></div>');
        supabase.from('suppliers').select('supplier_code,name,phone,area,accounts_payable').order('accounts_payable',{ascending:false}).then(function(r){var supp=r.data||[],html='<h2 class="text-lg font-black mb-4">🏭 الموردين</h2>';
        if(!supp.length){html+='<div class="text-center text-gray-400 py-10">لا يوجد موردين</div>';}else{for(var i=0;i<supp.length;i++){html+='<div class="card mb-2"><div class="flex justify-between"><span class="font-bold">'+supp[i].name+'</span><span class="font-black text-red-600">'+fmtNum(supp[i].accounts_payable)+' ج.م</span></div><p class="text-xs text-gray-400">'+supp[i].supplier_code+' | '+supp[i].phone+' | '+supp[i].area+'</p></div>';}}
        safeHTML(byId('mainContent'),html);});
    }
};
if('serviceWorker' in navigator){navigator.serviceWorker.register('../sw.js').catch(function(){});}
document.addEventListener('DOMContentLoaded',function(){App.init();});
</script>
</body>
</html>
