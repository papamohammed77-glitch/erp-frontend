<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>المدير العام | الروائع ERP</title>
    <link rel="manifest" href="../manifest.json">
    <meta name="theme-color" content="#1e3a8a">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dexie@3/dist/dexie.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:Tahoma,sans-serif;background:#f1f5f9}
        .auth-container{background:linear-gradient(135deg,#0f172a 0%,#1e3a8a 40%,#1e40af 100%)}
        .input-field:focus{border-color:#1e3a8a;box-shadow:0 0 0 3px rgba(30,58,138,0.1)}
        .card{background:#fff;border-radius:20px;padding:1.25rem;box-shadow:0 4px 15px rgba(0,0,0,0.05)}
        .stat-card{background:#fff;border-radius:16px;padding:1rem;box-shadow:0 4px 6px rgba(0,0,0,0.02)}
        .kpi-up{color:#10b981}.kpi-down{color:#ef4444}
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

<div id="loginScreen" class="fixed inset-0 z-[100] flex items-center justify-center auth-container p-4">
    <div class="bg-white rounded-[32px] shadow-2xl p-6 w-[92%] max-w-md">
        <div class="text-center mb-6"><div class="w-20 h-20 bg-gradient-to-br from-blue-800 to-blue-950 rounded-2xl mx-auto flex items-center justify-center shadow-lg mb-4"><i class="fa-solid fa-crown text-white text-3xl"></i></div><h1 class="font-black text-2xl text-gray-800">الروائع</h1><p class="text-xs text-gray-400">المدير العام</p></div>
        <h2 class="text-lg font-bold text-gray-700 text-center mb-4">تسجيل الدخول</h2>
        <div class="space-y-3"><div><input id="loginEmail" type="email" placeholder="البريد الإلكتروني" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-blue-800 outline-none font-bold text-sm"></div><div class="relative"><input id="loginPass" type="password" placeholder="كلمة السر" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-blue-800 outline-none font-bold text-sm pr-12"><button type="button" onclick="App.togglePass()" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 text-gray-400"><i id="passIcon" class="fa-solid fa-eye"></i></button></div></div>
        <button onclick="App.doLogin()" class="w-full bg-gradient-to-r from-blue-800 to-blue-900 text-white py-3.5 rounded-xl font-black text-sm shadow-lg mt-4">تسجيل الدخول</button>
        <p id="loginMsg" class="text-center text-xs text-red-500 font-bold mt-3 hidden"></p>
    </div>
</div>

<div id="mainApp" class="hidden flex flex-col h-full">
    <header class="bg-blue-900 text-white p-4 flex items-center justify-between sticky top-0 z-30 shadow-md flex-shrink-0">
        <span class="font-black text-sm">👑 المدير العام</span>
        <div class="flex items-center gap-2"><span class="text-xs font-bold" id="headerUserName"></span><button onclick="App.doLogout()" class="bg-white/10 w-8 h-8 rounded-full"><i class="fa-solid fa-arrow-right-from-bracket text-xs"></i></button></div>
    </header>
    <main id="mainContent" class="flex-1 overflow-y-auto p-4"></main>
</div>

<script>
var SUPABASE_URL = 'https://fiilmooggumokxanwiyx.supabase.co';
var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZpaWxtb29nZ3Vtb2t4YW53aXl4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg3MDkwOTIsImV4cCI6MjA5NDI4NTA5Mn0.LZScCxnCiRrTSCCBmTryszQpY1AwBgR2dkTBbC5kOc4';
var supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
var db = new Dexie('RW_GM'); db.version(1).stores({ meta: 'key' });
function byId(id) { return document.getElementById(id); }
function safeText(el, text) { if (el) el.textContent = text; }
function safeHTML(el, html) { if (el) el.innerHTML = html; }
function fmtNum(n) { return Number(n || 0).toLocaleString('ar-EG', {minimumFractionDigits: 2}); }

var App = {
    currentUser: null, charts: {},
    togglePass: function(){var p=byId('loginPass'),i=byId('passIcon');if(p.type==='password'){p.type='text';i.className='fa-solid fa-eye-slash';}else{p.type='password';i.className='fa-solid fa-eye';}},
    doLogin: function(){var e=byId('loginEmail').value.trim(),p=byId('loginPass').value.trim();if(!e||!p){byId('loginMsg').innerText='أدخل البيانات';byId('loginMsg').classList.remove('hidden');return;}byId('loginMsg').classList.add('hidden');var s=this;Swal.showLoading();supabase.auth.signInWithPassword({email:e,password:p}).then(function(r){Swal.close();if(r.error){byId('loginMsg').innerText=r.error.message;byId('loginMsg').classList.remove('hidden');}else{s.init();}}).catch(function(){Swal.close();});},
    init: function(){var s=this;supabase.auth.getSession().then(function(r){if(r.data&&r.data.session){s.currentUser=r.data.session.user;var m=s.currentUser.user_metadata||{},isO=(m.isOwner===true||m.isOwner==='true');if(!isO){Swal.fire({title:'غير مصرح',icon:'error'});supabase.auth.signOut();return;}safeText(byId('headerUserName'),m.name||s.currentUser.email);s.enterApp();}});},
    enterApp: function(){byId('loginScreen').classList.add('hidden');byId('mainApp').classList.remove('hidden');this.renderDashboard();},
    doLogout: function(){supabase.auth.signOut().then(function(){byId('mainApp').classList.add('hidden');byId('loginScreen').classList.remove('hidden');});},

    renderDashboard: function(){
        var s=this; safeHTML(byId('mainContent'),'<div class="text-center py-10"><i class="fa-solid fa-spinner fa-spin"></i></div>');
        var today=new Date().toISOString().split('T')[0],firstDay=new Date(new Date().getFullYear(),new Date().getMonth(),1).toISOString().split('T')[0];
        Promise.all([supabase.from('orders').select('total_amount').gte('order_date',firstDay).lte('order_date',today),supabase.from('purchase_orders').select('total_amount').gte('po_date',firstDay).lte('order_date',today),supabase.from('treasury').select('current_balance'),supabase.from('customers').select('debt'),supabase.from('users').select('email')]).then(function(r){
            var sales=0;for(var i=0;i<(r[0].data||[]).length;i++)sales+=Number(r[0].data[i].total_amount)||0;
            var purchases=0;for(var j=0;j<(r[1].data||[]).length;j++)purchases+=Number(r[1].data[j].total_amount)||0;
            var treasury=0;for(var k=0;k<(r[2].data||[]).length;k++)treasury+=Number(r[2].data[k].current_balance)||0;
            var debt=0;for(var l=0;l<(r[3].data||[]).length;l++)debt+=Number(r[3].data[l].debt)||0;
            var employees=(r[4].data||[]).length,profit=sales-purchases;
            var html='<h2 class="text-lg font-black mb-4">👑 لوحة القيادة – الشهر</h2>';
            html+='<div class="grid grid-cols-2 gap-3">';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">الإيرادات</p><p class="text-2xl font-black text-green-600">'+fmtNum(sales)+' ج.م</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">المشتريات</p><p class="text-2xl font-black text-red-600">'+fmtNum(purchases)+' ج.م</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">الربح</p><p class="text-2xl font-black '+(profit>=0?'text-blue-600':'text-red-600')+'">'+fmtNum(profit)+' ج.م</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">الخزائن</p><p class="text-2xl font-black text-blue-600">'+fmtNum(treasury)+' ج.م</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">الذمم</p><p class="text-2xl font-black text-amber-600">'+fmtNum(debt)+' ج.م</p></div>';
            html+='<div class="stat-card"><p class="text-xs text-gray-400">الموظفين</p><p class="text-2xl font-black text-indigo-600">'+employees+'</p></div>';
            html+='</div><p class="text-xs text-gray-400 mt-4 text-center">🏢 جميع الأقسام | التقارير المتقدمة في النظام الأم</p>';
            safeHTML(byId('mainContent'),html);
        });
    }
};
if('serviceWorker' in navigator){navigator.serviceWorker.register('../sw.js').catch(function(){});}
document.addEventListener('DOMContentLoaded',function(){App.init();});
</script>
</body>
</html>
