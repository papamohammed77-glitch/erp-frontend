<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>مسؤول الاستلام | الروائع ERP</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#059669">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/dexie@3/dist/dexie.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'Cairo',sans-serif;background:#f3f4f6;-webkit-tap-highlight-color:transparent}
        .card{background:#fff;border-radius:20px;padding:1.25rem;box-shadow:0 4px 15px rgba(0,0,0,0.05)}
        .btn-primary{background:#059669;color:#fff;padding:0.75rem 1.5rem;border-radius:12px;font-weight:700;border:none;cursor:pointer;width:100%}
        .btn-primary:active{background:#047857}
        .auth-container{background:linear-gradient(135deg,#064e3b 0%,#065f46 40%,#059669 100%)}
        .input-field:focus{border-color:#059669;box-shadow:0 0 0 3px rgba(5,150,105,0.1)}
        .pulse{animation:pulse 2s infinite}
        @keyframes pulse{0%{opacity:1}50%{opacity:0.6}100%{opacity:1}}
        .accordion-content{max-height:0;overflow:hidden;transition:max-height 0.3s ease-out}
        .accordion-content.open{max-height:2000px}
    </style>
</head>
<body class="h-screen flex flex-col overflow-hidden">

<!-- ============================================================ -->
<!-- شاشة الدخول -->
<!-- ============================================================ -->
<div id="loginScreen" class="fixed inset-0 z-[100] flex items-center justify-center auth-container p-4">
    <div class="bg-white rounded-[32px] shadow-2xl p-6 w-[92%] max-w-md">
        <div class="text-center mb-6">
            <div class="w-20 h-20 bg-gradient-to-br from-emerald-600 to-emerald-800 rounded-2xl mx-auto flex items-center justify-center shadow-lg mb-4">
                <i class="fa-solid fa-boxes-stacked text-white text-3xl"></i>
            </div>
            <h1 class="font-black text-2xl text-gray-800">الروائع</h1>
            <p class="text-xs text-gray-400 font-bold mt-1">مسؤول الاستلام</p>
        </div>
        <h2 class="text-lg font-bold text-gray-700 text-center mb-4">تسجيل الدخول إلى حسابك</h2>
        <div class="space-y-3">
            <div>
                <label class="block text-xs font-bold text-gray-600 mb-1">البريد الإلكتروني <span class="text-red-500">*</span></label>
                <input id="loginEmail" type="email" placeholder="example@domain.com" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-emerald-600 focus:bg-white outline-none font-bold text-sm transition-all">
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-600 mb-1">كلمة السر <span class="text-red-500">*</span></label>
                <div class="relative">
                    <input id="loginPass" type="password" placeholder="••••••••" class="input-field w-full p-3 bg-gray-50 rounded-xl border-2 border-gray-200 focus:border-emerald-600 focus:bg-white outline-none font-bold text-sm transition-all pr-12">
                    <button type="button" onclick="App.togglePass()" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 text-gray-400 hover:text-gray-600">
                        <i id="passIcon" class="fa-solid fa-eye"></i>
                    </button>
                </div>
            </div>
        </div>
        <button onclick="App.doLogin()" class="w-full bg-gradient-to-r from-emerald-600 to-emerald-700 text-white py-3.5 rounded-xl font-black text-sm shadow-lg shadow-emerald-200 hover:shadow-xl transition-all mt-4">
            تسجيل الدخول
        </button>
        <p id="loginMsg" class="text-center text-xs text-red-500 font-bold mt-3 hidden"></p>
    </div>
</div>

<!-- ============================================================ -->
<!-- التطبيق الرئيسي -->
<!-- ============================================================ -->
<div id="mainApp" class="hidden flex flex-col h-full">
    <header class="bg-emerald-700 text-white p-4 flex items-center justify-between sticky top-0 z-30 shadow-md flex-shrink-0">
        <div>
            <span class="font-black text-sm">📦 مسؤول الاستلام</span>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-xs font-bold" id="headerUserName"></span>
            <button onclick="App.doLogout()" class="bg-white/10 w-8 h-8 rounded-full"><i class="fa-solid fa-arrow-right-from-bracket text-xs"></i></button>
        </div>
    </header>

    <div class="flex gap-1 p-2 bg-white border-b overflow-x-auto flex-shrink-0">
        <button onclick="App.filterStatus('all')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm bg-emerald-600 text-white" id="tab-all">📋 الكل</button>
        <button onclick="App.filterStatus('Sent')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm text-gray-500" id="tab-Sent">🟡 مُرسلة</button>
        <button onclick="App.filterStatus('Partially Received')" class="whitespace-nowrap px-4 py-2 rounded-xl font-bold text-sm text-gray-500" id="tab-Partial">🟠 استلام جزئي</button>
    </div>

    <main id="mainContent" class="flex-1 overflow-y-auto p-4"></main>

    <!-- فوتر -->
    <footer class="bg-white border-t p-2 flex items-center justify-between flex-shrink-0">
        <div class="flex items-center gap-2 text-xs text-gray-500">
            <span id="onlineStatus" class="w-2 h-2 rounded-full bg-green-500"></span>
            <span id="syncStatus">متصل | آخر مزامنة: الآن</span>
        </div>
        <button onclick="App.syncNow()" class="text-xs text-emerald-600 font-bold"><i class="fa-solid fa-rotate ml-1"></i> مزامنة</button>
    </footer>
</div>

<script>
// ============================================================
// التهيئة
// ============================================================
var SUPABASE_URL = 'https://fiilmooggumokxanwiyx.supabase.co';
var SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZpaWxtb29nZ3Vtb2t4YW53aXl4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg3MDkwOTIsImV4cCI6MjA5NDI4NTA5Mn0.LZScCxnCiRrTSCCBmTryszQpY1AwBgR2dkTBbC5kOc4';
var supabase = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

// تهيئة Dexie.js للتخزين المحلي
var db = new Dexie('RW_Receiver');
db.version(1).stores({
    purchaseOrders: 'po_code, status, supplier_name, po_date',
    poDetails: '++id, po_code, item_code, item_name, qty_ordered, unit',
    meta: 'key'
});

function byId(id) { return document.getElementById(id); }
function safeHTML(el, html) { if (el) el.innerHTML = html; }
function safeText(el, text) { if (el) el.textContent = text; }
function fmtNum(n) { return Number(n || 0).toLocaleString('ar-EG'); }
function toast(m, t) { Swal.fire({ toast: true, position: 'top', icon: t || 'info', title: m, showConfirmButton: false, timer: 2000 }); }

// ============================================================
// التطبيق
// ============================================================
var App = {
    currentUser: null,
    purchaseOrders: [],
    currentFilter: 'all',
    activeTimers: {},

    // ==================== عدسة كلمة المرور ====================
    togglePass: function() {
        var passInput = byId('loginPass');
        var icon = byId('passIcon');
        if (passInput.type === 'password') {
            passInput.type = 'text';
            icon.className = 'fa-solid fa-eye-slash';
        } else {
            passInput.type = 'password';
            icon.className = 'fa-solid fa-eye';
        }
    },

    // ==================== الدخول ====================
    doLogin: function() {
        var email = byId('loginEmail').value.trim();
        var pass = byId('loginPass').value.trim();
        if (!email || !pass) {
            byId('loginMsg').innerText = 'أدخل البريد الإلكتروني وكلمة المرور';
            byId('loginMsg').classList.remove('hidden');
            return;
        }
        byId('loginMsg').classList.add('hidden');
        var self = this;
        Swal.showLoading();
        supabase.auth.signInWithPassword({ email: email, password: pass }).then(function(res) {
            Swal.close();
            if (res.error) {
                byId('loginMsg').innerText = res.error.message;
                byId('loginMsg').classList.remove('hidden');
            } else {
                self.init();
            }
        }).catch(function() {
            Swal.close();
            byId('loginMsg').innerText = 'فشل الاتصال بالخادم';
            byId('loginMsg').classList.remove('hidden');
        });
    },

    init: function() {
        var self = this;
        supabase.auth.getSession().then(function(res) {
            if (res.data && res.data.session) {
                self.currentUser = res.data.session.user;
                var meta = self.currentUser.user_metadata || {};
                var isOwner = (meta.isOwner === true || meta.isOwner === 'true' || meta.role === 'owner' || meta.role === 'مالك');
                var perms = meta.permissions || [];
                var hasAccess = isOwner || (Array.isArray(perms) && perms.indexOf('warehouse') !== -1);

                if (!hasAccess) {
                    Swal.fire({ title: 'غير مصرح', text: 'ليس لديك صلاحية الوصول للمخازن', icon: 'error' });
                    supabase.auth.signOut();
                    return;
                }

                var userName = meta.name || self.currentUser.email;

                // ✅ المالك يدخل مباشرة (لا نحتاج للتحقق من active_warehouse_role)
                if (isOwner) {
                    safeText(byId('headerUserName'), userName);
                    self.enterApp();
                    return;
                }

                // ✅ محاولة جلب active_warehouse_role من users (قد تفشل بسبب RLS)
                supabase.from('users').select('active_warehouse_role, name').eq('email', self.currentUser.email).maybeSingle().then(function(uRes) {
                    var userData = uRes.data || {};
                    var activeRole = userData.active_warehouse_role || '';
                    userName = userData.name || userName;

                    if (activeRole !== 'استلام') {
                        Swal.fire({
                            title: 'تنبيه',
                            text: 'دورك النشط حالياً هو "' + (activeRole || 'غير محدد') + '". الرجاء التواصل مع مشرف المخازن لتعيينك كمسؤول استلام.',
                            icon: 'warning'
                        });
                        supabase.auth.signOut();
                        return;
                    }

                    safeText(byId('headerUserName'), userName);
                    self.enterApp();
                }).catch(function() {
                    // ✅ خطة احتياطية: فشل RLS – نعتمد على user_metadata فقط
                    console.warn('تعذر جلب active_warehouse_role من users (RLS). استخدام user_metadata.');
                    var metaRole = meta.active_warehouse_role || '';
                    if (metaRole !== 'استلام' && !isOwner) {
                        Swal.fire({
                            title: 'تنبيه',
                            text: 'تعذر التحقق من دورك النشط. الرجاء التواصل مع مشرف المخازن.',
                            icon: 'warning'
                        });
                        supabase.auth.signOut();
                        return;
                    }
                    safeText(byId('headerUserName'), userName);
                    self.enterApp();
                });
            }
        });
    },

    enterApp: function() {
        byId('loginScreen').classList.add('hidden');
        byId('mainApp').classList.remove('hidden');
        this.loadPurchaseOrders();
        this.startOnlineMonitor();
    },

    doLogout: function() {
        var self = this;
        supabase.auth.signOut().then(function() {
            self.currentUser = null;
            self.purchaseOrders = [];
            byId('mainApp').classList.add('hidden');
            byId('loginScreen').classList.remove('hidden');
            byId('loginEmail').value = '';
            byId('loginPass').value = '';
            byId('loginMsg').classList.add('hidden');
        });
    },

    // ==================== فلترة الحالة ====================
    filterStatus: function(status) {
        this.currentFilter = status;
        var tabs = ['all', 'Sent', 'Partially Received'];
        for (var i = 0; i < tabs.length; i++) {
            var btn = byId('tab-' + tabs[i]);
            if (btn) { btn.classList.remove('bg-emerald-600', 'text-white'); btn.classList.add('text-gray-500'); }
        }
        var activeBtn = byId('tab-' + status);
        if (activeBtn) { activeBtn.classList.add('bg-emerald-600', 'text-white'); activeBtn.classList.remove('text-gray-500'); }
        this.renderList();
    },

    // ==================== تحميل أوامر الشراء ====================
    loadPurchaseOrders: function() {
        var self = this;
        safeHTML(byId('mainContent'), '<div class="text-center py-10 text-gray-400"><i class="fa-solid fa-spinner fa-spin text-2xl"></i><p class="mt-2">جاري تحميل أوامر الشراء...</p></div>');

        supabase.from('purchase_orders').select('po_code, po_date, supplier_name, status, total_amount').in('status', ['Sent', 'Partially Received']).order('po_date', { ascending: false }).then(function(res) {
            if (res.error) {
                safeHTML(byId('mainContent'), '<div class="text-center py-10 text-red-500">فشل تحميل البيانات</div>');
                return;
            }
            self.purchaseOrders = res.data || [];
            // تخزين محلي
            db.purchaseOrders.clear().then(function() {
                db.purchaseOrders.bulkPut(self.purchaseOrders);
            });
            self.renderList();
        }).catch(function() {
            // محاولة التحميل من IndexedDB
            db.purchaseOrders.toArray().then(function(cached) {
                if (cached.length > 0) {
                    self.purchaseOrders = cached;
                    self.renderList();
                    toast('تم التحميل من الذاكرة المحلية', 'info');
                } else {
                    safeHTML(byId('mainContent'), '<div class="text-center py-10 text-red-500">تعذر الاتصال ولا توجد بيانات محلية</div>');
                }
            });
        });
    },

    // ==================== عرض القائمة ====================
    renderList: function() {
        var filtered = this.purchaseOrders;
        if (this.currentFilter !== 'all') {
            filtered = this.purchaseOrders.filter(function(po) { return po.status === App.currentFilter; });
        }

        if (filtered.length === 0) {
            safeHTML(byId('mainContent'), '<div class="text-center py-10 text-gray-400"><i class="fa-solid fa-box-open text-4xl mb-3"></i><p>لا توجد أوامر شراء ' + (this.currentFilter === 'all' ? '' : 'بهذه الحالة') + '</p></div>');
            return;
        }

        var html = '<h2 class="text-lg font-black mb-4">📦 أوامر الشراء المعلقة</h2><p class="text-xs text-gray-500 mb-4">اضغط على أمر الشراء لبدء الاستلام</p>';

        for (var i = 0; i < filtered.length; i++) {
            var po = filtered[i];
            var statusColor = po.status === 'Sent' ? 'bg-amber-100 text-amber-700' : 'bg-orange-100 text-orange-700';
            var statusLabel = po.status === 'Sent' ? 'مُرسل' : 'استلام جزئي';
            var statusIcon = po.status === 'Sent' ? '🟡' : '🟠';

            html += '<div class="card mb-3 cursor-pointer" id="po-card-' + i + '">';
            html += '<div class="flex justify-between items-center" onclick="App.toggleAccordion(' + i + ', \'' + po.po_code + '\')">';
            html += '<div>';
            html += '<span class="font-bold text-lg">' + po.po_code + '</span>';
            html += '<p class="text-xs text-gray-400 mt-1"><i class="fa-solid fa-calendar ml-1"></i> ' + (po.po_date || '') + '</p>';
            html += '</div>';
            html += '<div class="flex items-center gap-2">';
            html += '<span class="px-2 py-1 rounded-full text-xs font-bold ' + statusColor + '">' + statusIcon + ' ' + statusLabel + '</span>';
            html += '<i class="fa-solid fa-chevron-down text-gray-400 text-sm" id="chevron-' + i + '"></i>';
            html += '</div>';
            html += '</div>';

            // المحتوى المتوسع (مخفي افتراضياً)
            html += '<div class="accordion-content" id="accordion-' + i + '">';
            html += '<div class="border-t mt-3 pt-3">';
            html += '<p class="text-xs text-gray-500 mb-2"><i class="fa-solid fa-clock ml-1"></i> العداد: <span id="timer-' + i + '" class="font-bold text-emerald-600">00:00</span></p>';
            html += '<div id="details-' + i + '" class="text-center text-gray-400 text-sm py-4">جاري تحميل الأصناف...</div>';
            html += '<button id="btn-receive-' + i + '" class="btn-primary mt-4 hidden" onclick="App.submitReceiving(' + i + ', \'' + po.po_code + '\')"><i class="fa-solid fa-check ml-2"></i> اعتماد الاستلام</button>';
            html += '</div>';
            html += '</div>';

            html += '</div>';
        }

        safeHTML(byId('mainContent'), html);
    },

    // ==================== Accordion ====================
    toggleAccordion: function(index, poCode) {
        var accordion = byId('accordion-' + index);
        var chevron = byId('chevron-' + index);
        var detailsDiv = byId('details-' + index);
        var btnReceive = byId('btn-receive-' + index);

        if (!accordion) return;

        var isOpen = accordion.classList.contains('open');

        if (isOpen) {
            // إغلاق
            accordion.classList.remove('open');
            if (chevron) chevron.className = 'fa-solid fa-chevron-down text-gray-400 text-sm';
            // إيقاف العداد
            if (this.activeTimers[index]) {
                clearInterval(this.activeTimers[index]);
                delete this.activeTimers[index];
            }
        } else {
            // فتح
            accordion.classList.add('open');
            if (chevron) chevron.className = 'fa-solid fa-chevron-up text-gray-400 text-sm';
            // بدء العداد
            this.startTimer(index);
            // تحميل التفاصيل
            this.loadPODetails(index, poCode);
        }
    },

    // ==================== العداد ====================
    startTimer: function(index) {
        var self = this;
        var startTime = new Date();
        var timerEl = byId('timer-' + index);

        if (this.activeTimers[index]) {
            clearInterval(this.activeTimers[index]);
        }

        this.activeTimers[index] = setInterval(function() {
            var diff = Math.floor((new Date() - startTime) / 1000);
            var hours = Math.floor(diff / 3600);
            var minutes = Math.floor((diff % 3600) / 60);
            var seconds = diff % 60;
            var timeStr = (hours > 0 ? String(hours).padStart(2, '0') + ':' : '') +
                          String(minutes).padStart(2, '0') + ':' +
                          String(seconds).padStart(2, '0');
            if (timerEl) safeText(timerEl, timeStr);
        }, 1000);
    },

    // ==================== تحميل تفاصيل أمر الشراء ====================
    loadPODetails: function(index, poCode) {
        var self = this;
        var detailsDiv = byId('details-' + index);
        var btnReceive = byId('btn-receive-' + index);

        if (!detailsDiv) return;

        safeHTML(detailsDiv, '<div class="text-center text-gray-400 text-sm py-4"><i class="fa-solid fa-spinner fa-spin"></i> جاري التحميل...</div>');

        supabase.from('purchase_order_details').select('item_code, item_name, qty_ordered, unit').eq('po_code', poCode).then(function(res) {
            if (res.error || !res.data || res.data.length === 0) {
                // ✅ خطة احتياطية: محاولة التحميل من IndexedDB
                db.poDetails.where('po_code').equals(poCode).toArray().then(function(cached) {
                    if (cached.length > 0) {
                        self.renderPODetailItems(index, cached);
                        toast('تم تحميل الأصناف من الذاكرة المحلية', 'info');
                    } else {
                        safeHTML(detailsDiv, '<div class="text-center text-gray-400 text-sm py-4">لا توجد أصناف ولا بيانات محلية</div>');
                    }
                });
                return;
            }

            var items = res.data;

            // ✅ تخزين في IndexedDB
            db.poDetails.where('po_code').equals(poCode).delete().then(function() {
                for (var i = 0; i < items.length; i++) {
                    items[i].po_code = poCode;
                }
                db.poDetails.bulkPut(items);
            });

            self.renderPODetailItems(index, items);
        }).catch(function() {
            // ✅ خطة احتياطية: محاولة التحميل من IndexedDB عند فشل الاتصال
            db.poDetails.where('po_code').equals(poCode).toArray().then(function(cached) {
                if (cached.length > 0) {
                    self.renderPODetailItems(index, cached);
                    toast('تم تحميل الأصناف من الذاكرة المحلية', 'info');
                } else {
                    safeHTML(detailsDiv, '<div class="text-center text-red-500 text-sm py-4">فشل تحميل الأصناف ولا توجد بيانات محلية</div>');
                }
            });
        });
    },

    // ==================== عرض تفاصيل الأصناف ====================
    renderPODetailItems: function(index, items) {
        var detailsDiv = byId('details-' + index);
        var btnReceive = byId('btn-receive-' + index);

        if (!detailsDiv) return;

        var html = '';

        for (var i = 0; i < items.length; i++) {
            var item = items[i];
            html += '<div class="flex items-center justify-between p-2 border-b" id="item-row-' + index + '-' + i + '">';
            html += '<div class="flex-1">';
            html += '<p class="font-bold text-sm">' + (item.item_name || '') + '</p>';
            html += '<p class="text-xs text-gray-400">' + (item.item_code || '') + ' | الوحدة: ' + (item.unit || 'حبة') + '</p>';
            html += '<p class="text-xs text-gray-500">الكمية المطلوبة: <span class="font-bold">' + (item.qty_ordered || 0) + '</span></p>';
            html += '</div>';
            html += '<div class="flex items-center gap-2">';
            html += '<input type="number" id="qty-' + index + '-' + i + '" value="' + (item.qty_ordered || 0) + '" min="0" max="' + (item.qty_ordered || 0) + '" class="w-20 p-2 border rounded-lg text-center font-bold text-sm" onchange="App.onQtyChange(' + index + ', ' + i + ', ' + (item.qty_ordered || 0) + ')">';
            html += '</div>';
            html += '</div>';

            html += '<div class="p-2 bg-amber-50 rounded-lg mb-2 hidden" id="reason-' + index + '-' + i + '">';
            html += '<label class="text-xs font-bold text-amber-700 block mb-1">سبب الفرق:</label>';
            html += '<input type="text" id="reason-input-' + index + '-' + i + '" class="w-full p-2 border rounded-lg text-sm" placeholder="سبب نقص الكمية...">';
            html += '</div>';
        }

        safeHTML(detailsDiv, html);

        if (btnReceive) btnReceive.classList.remove('hidden');
    },

    // ==================== تغيير الكمية (إظهار/إخفاء سبب الفرق) ====================
    onQtyChange: function(poIndex, itemIndex, orderedQty) {
        var qtyInput = byId('qty-' + poIndex + '-' + itemIndex);
        var reasonDiv = byId('reason-' + poIndex + '-' + itemIndex);

        if (!qtyInput || !reasonDiv) return;

        var receivedQty = parseInt(qtyInput.value) || 0;

        if (receivedQty < orderedQty) {
            reasonDiv.classList.remove('hidden');
        } else {
            reasonDiv.classList.add('hidden');
        }
    },

    // ==================== اعتماد الاستلام ====================
    submitReceiving: function(index, poCode) {
        var self = this;
        var itemsReceived = [];

        // تجميع البيانات من الحقول
        var detailsDiv = byId('details-' + index);
        if (!detailsDiv) return;

        var qtyInputs = detailsDiv.querySelectorAll('input[type="number"]');

        for (var i = 0; i < qtyInputs.length; i++) {
            var qty = parseInt(qtyInputs[i].value) || 0;

            var rowId = qtyInputs[i].id;
            var rowParts = rowId.split('-');
            var rowIndex = rowParts[rowParts.length - 1];

            var itemCode = '';
            var itemName = '';

            var row = byId('item-row-' + index + '-' + rowIndex);
            if (row) {
                var nameEl = row.querySelector('.font-bold');
                var codeEl = row.querySelector('.text-xs');
                if (nameEl) itemName = nameEl.textContent.trim();
                if (codeEl) {
                    var codeText = codeEl.textContent.trim();
                    var codeMatch = codeText.split('|')[0].trim();
                    itemCode = codeMatch;
                }
            }

            var reasonInput = byId('reason-input-' + index + '-' + rowIndex);
            var reason = reasonInput ? reasonInput.value.trim() : '';

            itemsReceived.push({
                itemCode: itemCode,
                itemName: itemName,
                receivedQty: qty,
                reason: reason
            });
        }

        // ✅ التحقق: هل تم استلام شيء؟
        var totalReceived = 0;
        for (var j = 0; j < itemsReceived.length; j++) {
            totalReceived += itemsReceived[j].receivedQty;
        }
        if (totalReceived === 0) {
            toast('لم يتم استلام أي كمية', 'warning');
            return;
        }

        Swal.fire({
            title: 'تأكيد الاستلام',
            text: 'سيتم اعتماد استلام ' + itemsReceived.length + ' صنف لأمر الشراء ' + poCode + '. متابعة؟',
            icon: 'question',
            showCancelButton: true,
            confirmButtonText: 'نعم، اعتماد الاستلام',
            cancelButtonText: 'إلغاء'
        }).then(function(result) {
            if (!result.isConfirmed) return;

            Swal.showLoading();

            supabase.auth.getSession().then(function(ses) {
                var token = (ses && ses.data && ses.data.session) ? ses.data.session.access_token : null;
                return fetch(SUPABASE_URL + '/functions/v1/receive-purchase', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
                    body: JSON.stringify({
                        po_code: poCode,
                        itemsReceived: itemsReceived,
                        notes: ''
                    })
                });
            }).then(function(res) {
                return res.json();
            }).then(function(json) {
                Swal.close();
                if (json.success) {
                    toast('تم اعتماد الاستلام بنجاح', 'success');

                    // إيقاف العداد
                    if (self.activeTimers[index]) {
                        clearInterval(self.activeTimers[index]);
                        delete self.activeTimers[index];
                    }

                    // مسح التفاصيل من IndexedDB بعد الاعتماد الناجح
                    db.poDetails.where('po_code').equals(poCode).delete();

                    // إزالة أمر الشراء من القائمة محلياً
                    var newPOs = [];
                    for (var k = 0; k < self.purchaseOrders.length; k++) {
                        if (self.purchaseOrders[k].po_code !== poCode) {
                            newPOs.push(self.purchaseOrders[k]);
                        }
                    }
                    self.purchaseOrders = newPOs;
                    self.renderList();
                } else {
                    toast(json.error || json.msg || 'فشل اعتماد الاستلام', 'error');
                }
            }).catch(function(e) {
                Swal.close();
                toast('فشل الاتصال بالخادم', 'error');
            });
        });
    },

    // ==================== مراقبة الاتصال ====================
    startOnlineMonitor: function() {
        var self = this;
        function updateStatus() {
            var statusEl = byId('onlineStatus');
            var syncEl = byId('syncStatus');
            if (navigator.onLine) {
                if (statusEl) statusEl.className = 'w-2 h-2 rounded-full bg-green-500';
                if (syncEl) safeText(syncEl, 'متصل | آخر مزامنة: ' + new Date().toLocaleTimeString('ar-EG'));
            } else {
                if (statusEl) statusEl.className = 'w-2 h-2 rounded-full bg-red-500';
                if (syncEl) safeText(syncEl, 'غير متصل | يعمل محلياً');
            }
        }
        updateStatus();
        window.addEventListener('online', updateStatus);
        window.addEventListener('offline', updateStatus);
    },

    syncNow: function() {
        toast('جاري المزامنة...', 'info');
        this.loadPurchaseOrders();
    }
};

// ============================================================
// بدء التشغيل
// ============================================================
document.addEventListener('DOMContentLoaded', function() { App.init(); });

// Service Worker
if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('sw.js').catch(function() {});
}
</script>
